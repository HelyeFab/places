# Australia 2026 Places - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# FIREBASE CONFIGURATION (REQUIRED)
# ============================================
# Get these values from Firebase Console:
# https://console.firebase.google.com/ > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ============================================
# APPLICATION CONFIGURATION (REQUIRED)
# ============================================
# Your production domain (for SEO and metadata)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SENTRY ERROR MONITORING (OPTIONAL)
# ============================================
# Get these values from Sentry.io:
# https://sentry.io/ > Settings > Projects > [Your Project]
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# For source map uploads (create at: Sentry > Settings > Auth Tokens)
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ============================================
# NODE ENVIRONMENT (AUTO-CONFIGURED)
# ============================================
# Usually set automatically by your deployment platform
# NODE_ENV=development  # or production

# ============================================
# NOTES
# ============================================
# 1. Never commit .env.local to git (already in .gitignore)
# 2. All NEXT_PUBLIC_* variables are exposed to the browser
# 3. Variables without NEXT_PUBLIC_ are server-side only
# 4. Restart dev server after changing env variables
# 5. See PRODUCTION_DEPLOYMENT.md for full deployment guide
